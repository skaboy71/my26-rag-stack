    CONFIG_PATH.write_text(json.dumps(cfg, indent=2))


# ── Embedding ──────────────────────────────────────────────────────────────────

def embed(texts: list[str], cfg: dict) -> list[list[float]]:
    import ollama as ol
    client = ol.Client(host=cfg["ollama_url"])
    results = []
    batch = cfg.get("embed_batch_size", 32)
    for i in range(0, len(texts), batch):
        resp = client.embed(model=cfg["embedding_model"], input=texts[i:i+batch])
        results.extend(resp.embeddings)
    return results


# ── Reranking ──────────────────────────────────────────────────────────────────

_reranker = None

def get_reranker(cfg: dict):
    global _reranker
    if _reranker is None:
        from sentence_transformers import CrossEncoder
        _reranker = CrossEncoder(cfg["reranker_model"])
    return _reranker


def rerank(query: str, results: list[dict], cfg: dict) -> list[dict]:
    if not results:
        return results
    model = get_reranker(cfg)
    pairs = [(query, r["text"]) for r in results]
    scores = model.predict(pairs).tolist()
    for r, s in zip(results, scores):
        r["score"] = float(s)
    return sorted(results, key=lambda x: x["score"], reverse=True)


# ── Qdrant ─────────────────────────────────────────────────────────────────────

def get_qdrant(cfg: dict):
    from qdrant_client import QdrantClient
    return QdrantClient(url=cfg["qdrant_url"], timeout=10)


def ensure_collection(client, name: str, vector_size: int = 4096):
    from qdrant_client.models import Distance, VectorParams
    existing = [c.name for c in client.get_collections().collections]
    if name not in existing:
        client.create_collection(
            collection_name=name,
            vectors_config=VectorParams(size=vector_size, distance=Distance.COSINE),
        )
        print(f"✅ Created collection: {name}")


def upsert_chunks(client, collection: str, chunks: list[dict], vectors: list[list[float]]):
    from qdrant_client.models import PointStruct
    points = []
    for chunk, vec in zip(chunks, vectors):
        uid = hashlib.sha256((chunk["text"] + str(chunk["metadata"])).encode()).hexdigest()[:16]
        points.append(PointStruct(
            id=int(uid, 16) % (2**63),
            vector=vec,
            payload={"text": chunk["text"], **chunk["metadata"]}
        ))
    client.upsert(collection_name=collection, points=points)


def search_collection(client, collection: str, vector: list[float], top_k: int) -> list[dict]:
    try:
        result = client.query_points(
            collection_name=collection,
            query=vector,
            limit=top_k,
            with_payload=True,
        )
        results = []
        for h in result.points:
            payload = dict(h.payload)
            text = payload.pop("text", "")
            results.append({"text": text, "score": h.score, "collection": collection, "metadata": payload})
        return results
    except Exception as e:
        logger.warning(f"Search failed on {collection}: {e}")
        return []


# ── Chunking ───────────────────────────────────────────────────────────────────

def chunk_text(text: str, metadata: dict) -> list[dict]:
    """Split text into overlapping chunks at sentence/paragraph boundaries."""
    paragraphs = re.split(r'\n{2,}', text.strip())
    chunks, current, current_len = [], [], 0
    for para in paragraphs:
        para = para.strip()
        if not para:
            continue
        words = para.split()
        if current_len + len(words) > CHUNK_SIZE:
            if current:
                chunk_text_str = " ".join(current)
                chunks.append({"text": chunk_text_str, "metadata": dict(metadata)})
            overlap = current[-CHUNK_OVERLAP:] if len(current) > CHUNK_OVERLAP else current
            current = overlap + words
            current_len = len(current)
        else:
            current.extend(words)
            current_len += len(words)
    if current:
        chunks.append({"text": " ".join(current), "metadata": dict(metadata)})
    return chunks if chunks else [{"text": text[:4000], "metadata": dict(metadata)}]


def chunk_code(path: Path) -> list[dict]:
    """Tree-sitter based chunking by symbol boundary."""
    try:
        import tree_sitter_languages
        from tree_sitter import Language, Parser
        lang_map = {
            ".py": "python", ".java": "java", ".js": "javascript",
            ".jsx": "javascript", ".ts": "typescript", ".tsx": "typescript",
            ".html": "html", ".css": "css",
        }
        suffix = path.suffix.lower()
        lang_name = lang_map.get(suffix)
        if not lang_name:
            return chunk_text(path.read_text(errors="replace"),
                              {"file_path": str(path), "language": suffix.lstrip(".")})

        lang = Language(tree_sitter_languages.get_language(lang_name))
        parser = Parser(lang)
        src = path.read_bytes()
        tree = parser.parse(src)

        symbol_types = {
            "python": {"function_definition", "class_definition"},
            "java": {"method_declaration", "class_declaration"},
            "javascript": {"function_declaration", "arrow_function", "class_declaration", "method_definition"},
            "typescript": {"function_declaration", "arrow_function", "class_declaration", "method_definition"},
            "html": {"element"}, "css": {"rule_set"},
        }

        chunks = []
        types = symbol_types.get(lang_name, set())

        def walk(node):
            if node.type in types:
                text = src[node.start_byte:node.end_byte].decode(errors="replace")
                name = ""
                for child in node.children:
                    if child.type == "identifier":
                        name = src[child.start_byte:child.end_byte].decode()
                        break
                chunks.append({
                    "text": text,
                    "metadata": {
                        "file_path": str(path),
                        "language": lang_name,
                        "symbol_name": name,
                        "symbol_type": node.type,
                        "start_line": node.start_point[0] + 1,
                        "end_line": node.end_point[0] + 1,
                    }
                })
            else:
                for child in node.children:
                    walk(child)

        walk(tree.root_node)
        if not chunks:
            return chunk_text(src.decode(errors="replace"),
                              {"file_path": str(path), "language": lang_name})
        return chunks
    except ImportError:
        logger.warning("tree-sitter-languages not installed — falling back to text chunking")
        return chunk_text(path.read_text(errors="replace"),
                          {"file_path": str(path), "language": path.suffix.lstrip(".")})


def extract_file(path: Path) -> str:
    """Extract text from PDF, docx, or plain text."""
    suffix = path.suffix.lower()
    if suffix == ".pdf":
        try:
            from pypdf import PdfReader
            reader = PdfReader(str(path))
            return "\n\n".join(p.extract_text() or "" for p in reader.pages)
        except Exception as e:
            logger.error(f"PDF extraction failed: {e}")
            return ""
    elif suffix == ".docx":
        try:
            from docx import Document
            doc = Document(str(path))
            return "\n\n".join(p.text for p in doc.paragraphs if p.text.strip())
        except Exception as e:
            logger.error(f"DOCX extraction failed: {e}")
            return ""
    else:
        return path.read_text(errors="replace")


# ── Web Crawler ────────────────────────────────────────────────────────────────

def crawl_url(url: str, depth: int = 0, ignore_robots: bool = False) -> list[dict]:
    """Crawl URL with Playwright + BeautifulSoup. Returns list of {url, text, title}."""
    try:
        from playwright.sync_api import sync_playwright
        from bs4 import BeautifulSoup
        from urllib.parse import urljoin, urlparse
        import urllib.robotparser

        seed_parsed = urlparse(url)
        seed_domain = seed_parsed.netloc
        seed_prefix = seed_parsed.scheme + "://" + seed_parsed.netloc + seed_parsed.path

        rp = urllib.robotparser.RobotFileParser()
        rp.allow_all = True  # default: allow everything unless real robots.txt says otherwise
        if not ignore_robots:
            try:
                import urllib.request
                robots_url = f"{seed_parsed.scheme}://{seed_domain}/robots.txt"
                with urllib.request.urlopen(robots_url, timeout=5) as resp:
                    content = resp.read().decode(errors="replace")
                if "user-agent" in content.lower() and "<html" not in content.lower():
                    rp.allow_all = False
                    rp.set_url(robots_url)
                    rp.parse(content.splitlines())
                    rp._last_checked = 1
            except Exception:
                pass

        visited, queue, pages = set(), [(url, 0)], []

        with sync_playwright() as p:
            browser = p.chromium.launch(headless=True)
            page = browser.new_page()

            while queue:
                current_url, current_depth = queue.pop(0)
                if current_url in visited:
                    continue
                visited.add(current_url)

                if not ignore_robots and not rp.can_fetch("*", current_url):
                    continue

                try:
                    page.goto(current_url, wait_until="domcontentloaded", timeout=30000)
                    page.wait_for_timeout(500)
                    html = page.content()
                except Exception as e:
                    logger.warning(f"Failed to load {current_url}: {e}")
                    continue

                soup = BeautifulSoup(html, "html.parser")
                for tag in soup(["script", "style", "nav", "footer", "header"]):
                    tag.decompose()
                title = soup.title.string.strip() if soup.title else ""
                text = soup.get_text(separator="\n", strip=True)
                pages.append({"url": current_url, "text": text, "title": title})

                if current_depth < depth:
                    for a in soup.find_all("a", href=True):
                        href = urljoin(current_url, a["href"]).split("#")[0]
                        parsed = urlparse(href)
                        if (parsed.netloc == seed_domain
                                and href.startswith(seed_prefix)
                                and href not in visited
                                and parsed.scheme in ("http", "https")):
                            queue.append((href, current_depth + 1))

            browser.close()
        return pages
    except ImportError:
        print("❌ playwright not installed. Run: pip install playwright && playwright install chromium")
        sys.exit(1)


# ── Ingest helpers ─────────────────────────────────────────────────────────────

def ingest_chunks(chunks: list[dict], collection: str, cfg: dict):
    if not chunks:
        print("⚠️  No chunks to ingest")
        return
    client = get_qdrant(cfg)
    texts = [c["text"] for c in chunks]
    print(f"🔄 Embedding {len(chunks)} chunks...")
    vectors = embed(texts, cfg)
    vector_size = len(vectors[0])
    ensure_collection(client, collection, vector_size)
    upsert_chunks(client, collection, chunks, vectors)
    print(f"✅ Ingested {len(chunks)} chunks → {collection}")


def delete_file_points(client, collection: str, file_path: str):
    """Delete all Qdrant points whose file_path metadata matches."""
    from qdrant_client.models import Filter, FieldCondition, MatchValue, FilterSelector
    try:
        client.delete(
            collection_name=collection,
            points_selector=FilterSelector(
                filter=Filter(must=[FieldCondition(key="file_path", match=MatchValue(value=file_path))])
            )
        )
    except Exception as e:
        logger.warning(f"Could not delete points for {file_path}: {e}")


def delete_url_points(client, collection: str, url: str):
    """Delete all Qdrant points whose source_url metadata matches."""
    from qdrant_client.models import Filter, FieldCondition, MatchValue, FilterSelector
    try:
        client.delete(
            collection_name=collection,
            points_selector=FilterSelector(
                filter=Filter(must=[FieldCondition(key="source_url", match=MatchValue(value=url))])
            )
        )
    except Exception as e:
        logger.warning(f"Could not delete points for {url}: {e}")


def _collect_dir_files(dirpath: Path, code_only: bool = False) -> list[Path]:
    code_exts = {".py", ".java", ".js", ".jsx", ".ts", ".tsx", ".html", ".css"}
    files = []
    for f in sorted(dirpath.rglob("*")):
        if not f.is_file():
            continue
        if any(p.startswith(".") for p in f.parts):
            continue
        if code_only and f.suffix.lower() not in code_exts:
            continue
        files.append(f)
    return files


def refresh_dir_source(source: dict, cfg: dict) -> dict:
    """Delta-refresh a dir or codebase persistent source. Returns updated source entry."""
    dirpath = Path(source["path"])
    collection = source["collection"]
    source_type = source.get("type", "dir")
    old_manifest = source.get("manifest", {})  # {str(path): mtime}

    if not dirpath.is_dir():
        print(f"⚠️  Source path missing: {dirpath}")
        return source

    code_only = source_type == "codebase"
    current_files = {str(f): f.stat().st_mtime for f in _collect_dir_files(dirpath, code_only)}

    # Files removed since last ingest → delete from Qdrant
    removed = set(old_manifest) - set(current_files)
    if removed:
        client = get_qdrant(cfg)
        for path_str in removed:
            delete_file_points(client, collection, path_str)
            print(f"   🗑️  Removed: {Path(path_str).name}")

    # Files added or modified → re-embed
    to_ingest = {p: m for p, m in current_files.items()
                 if p not in old_manifest or old_manifest[p] != m}

    if to_ingest:
        all_chunks = []
        for path_str in sorted(to_ingest):
            f = Path(path_str)
            try:
                if code_only:
                    all_chunks.extend(chunk_code(f))
                else:
                    suffix = f.suffix.lower()
                    if suffix == ".pdf":
                        text = extract_file(f)
                        meta = {"file_path": path_str, "file_name": f.name, "file_type": "pdf",
                                "ingested_date": datetime.now(timezone.utc).isoformat()}
                        all_chunks.extend(chunk_text(text, meta))
                    elif suffix == ".docx":
                        text = extract_file(f)
                        meta = {"file_path": path_str, "file_name": f.name, "file_type": "docx"}
                        all_chunks.extend(chunk_text(text, meta))
                    else:
                        text = extract_file(f)
                        meta = {"file_path": path_str, "file_name": f.name,
                                "file_type": suffix.lstrip(".")}
                        all_chunks.extend(chunk_text(text, meta))
            except Exception as e:
                logger.warning(f"Skipping {f}: {e}")
        if all_chunks:
            # Delete old chunks for changed files before upserting new ones
            client = get_qdrant(cfg)
            for path_str in to_ingest:
                delete_file_points(client, collection, path_str)
            ingest_chunks(all_chunks, collection, cfg)
        print(f"   ✅ {len(to_ingest)} files updated, {len(removed)} removed")
    else:
        print(f"   ✅ No changes ({len(current_files)} files)")

    source["manifest"] = current_files
    return source


def refresh_url_source(source: dict, cfg: dict) -> dict:
    """Delta-refresh a URL persistent source. Returns updated source entry."""
    url = source["url"]
    collection = source["collection"]
    depth = source.get("depth", 0)
    old_hashes = source.get("page_hashes", {})  # {url: sha256(text[:4096])}

    print(f"🔄 Crawling {url} (depth={depth})...")
    pages = crawl_url(url, depth=depth, ignore_robots=source.get("ignore_robots", False))
    print(f"   Found {len(pages)} pages")

    seed_domain = url.split("/")[2] if "//" in url else ""
    new_hashes = {}
    to_embed = []
    unchanged = 0

    for pg in pages:
        content_hash = hashlib.sha256(pg["text"].encode()).hexdigest()
        new_hashes[pg["url"]] = content_hash
        if old_hashes.get(pg["url"]) == content_hash:
            unchanged += 1
            continue
        to_embed.append(pg)

    # Pages that disappeared → delete from Qdrant
    removed_urls = set(old_hashes) - set(new_hashes)
    if removed_urls:
        client = get_qdrant(cfg)
        for removed_url in removed_urls:
            delete_url_points(client, collection, removed_url)
        print(f"   🗑️  Removed {len(removed_urls)} disappeared pages")

    if to_embed:
        all_chunks = []
        for pg in to_embed:
            # Delete old chunks for this URL before re-embedding
            if pg["url"] in old_hashes:
                client = get_qdrant(cfg)
                delete_url_points(client, collection, pg["url"])
            meta = {
                "source_url": pg["url"], "page_title": pg["title"],
                "domain": seed_domain, "depth": depth, "crawl_root": url,
                "fetched_date": datetime.now(timezone.utc).date().isoformat(),
            }
            all_chunks.extend(chunk_text(pg["text"], meta))
        ingest_chunks(all_chunks, collection, cfg)
        print(f"   ✅ {len(to_embed)} pages updated, {unchanged} unchanged")
    else:
        print(f"   ✅ No changes ({unchanged} pages)")

    source["page_hashes"] = new_hashes
    return source


def _save_persistent_source(cfg: dict, entry: dict):
    """Add or update a persistent source entry, matched by type+path/url."""
    sources = cfg.get("persistent_sources", [])
    key = entry.get("path") or entry.get("url")
    for i, s in enumerate(sources):
        if (s.get("path") or s.get("url")) == key and s.get("type") == entry.get("type"):
            sources[i] = entry
            cfg["persistent_sources"] = sources
            save_config(cfg)
            return
    sources.append(entry)
    cfg["persistent_sources"] = sources
    save_config(cfg)


