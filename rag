def cmd_query(args, cfg):
    import concurrent.futures

    query = args.query
    top_k = args.top_k or cfg["default_top_k"]
    collections = args.collections.split(",") if args.collections else cfg["collections"]

    # Embed query
    try:
        vec = embed([query], cfg)[0]
    except Exception as e:
        print(f"❌ Embedding failed: {e}", file=sys.stderr)
        sys.exit(1)

    # Parallel search across collections
    retrieve_k = top_k * 4
    results = []
    try:
        client = get_qdrant(cfg)
        with concurrent.futures.ThreadPoolExecutor() as ex:
            futures = {ex.submit(search_collection, client, c, vec, retrieve_k): c for c in collections}
            for f in concurrent.futures.as_completed(futures):
                results.extend(f.result())
    except Exception as e:
        print(f"❌ Qdrant search failed: {e}", file=sys.stderr)
        sys.exit(1)

    if not results:
        if args.json:
            print("[]")
        else:
            print("No results found.")
        return

    # Rerank or sort by embedding score
    if not args.no_rerank:
        try:
            results = rerank(query, results, cfg)
        except Exception as e:
            logger.warning(f"Reranking failed, falling back to embedding scores: {e}")
            results.sort(key=lambda x: x["score"], reverse=True)
    else:
        results.sort(key=lambda x: x["score"], reverse=True)

    results = results[:top_k]

    if args.json:
        print(json.dumps(results, indent=2))
    else:
        for i, r in enumerate(results, 1):
            score = r["score"]
            coll = r["collection"]
            meta = r["metadata"]
            src = meta.get("file_path") or meta.get("source_url") or meta.get("symbol_name") or ""
            print(f"\n[{i}] score={score:.3f} | {coll} | {src}")
            print("─" * 60)
            print(r["text"][:400])


def cmd_add(args, cfg):
    collection = args.collection or "files"

    if args.web is not None:
        sources = cfg.get("web_sources", [])
        if not sources:
            print("❌ No web_sources configured in rag_personal_config.json")
            print("   Add entries like: {\"name\": \"spring-docs\", \"url\": \"https://...\", \"depth\": 2, \"collection\": \"web\"}")
            sys.exit(1)
        if args.web == "__all__":
            targets = sources
        else:
            targets = [s for s in sources if s["name"] == args.web]
            if not targets:
                names = [s["name"] for s in sources]
                print(f"❌ Web source '{args.web}' not found. Available: {', '.join(names)}")
                sys.exit(1)
        for ws in targets:
            url = ws["url"]
            depth = ws.get("depth", 0)
            coll = args.collection or ws.get("collection", "web")
            print(f"🌐 Crawling: {ws['name']} — {url} (depth={depth})")
            pages = crawl_url(url, depth=depth, ignore_robots=ws.get("ignore_robots", False))
            print(f"   Found {len(pages)} pages")
            page_hashes, all_chunks = {}, []
            seed_domain = url.split("/")[2] if "//" in url else ""
            for pg in pages:
                page_hashes[pg["url"]] = hashlib.sha256(pg["text"].encode()).hexdigest()
                meta = {"source_url": pg["url"], "page_title": pg["title"],
                        "domain": seed_domain, "depth": depth, "crawl_root": url,
                        "fetched_date": datetime.now(timezone.utc).date().isoformat(),
                        "web_source_name": ws["name"]}
                all_chunks.extend(chunk_text(pg["text"], meta))
            ingest_chunks(all_chunks, coll, cfg)
            cfg = load_config()
            _save_persistent_source(cfg, {
                "type": "url", "url": url, "depth": depth, "collection": coll,
                "ignore_robots": ws.get("ignore_robots", False),
                "page_hashes": page_hashes, "web_source_name": ws["name"],
            })
            print(f"   ✅ '{ws['name']}' saved as persistent source ({len(page_hashes)} pages tracked)")
        return

    if args.obsidian is not None:
        vaults = cfg.get("obsidian_vaults", [])
        if not vaults:
            print("❌ No obsidian_vaults configured in rag_personal_config.json")
            sys.exit(1)
        if args.obsidian == "__all__":
            targets = vaults
        else:
            targets = [v for v in vaults if v["name"] == args.obsidian]
            if not targets:
                names = [v["name"] for v in vaults]
                print(f"❌ Vault '{args.obsidian}' not found. Available: {', '.join(names)}")
                sys.exit(1)
        for vault in targets:
            print(f"🗂️  Ingesting Obsidian vault: {vault['name']} ({vault['path']})")
            dirpath = Path(vault["path"])
            if not dirpath.is_dir():
                print(f"   ❌ Path not found: {dirpath}")
                continue
            coll = args.collection or vault.get("collection", "files")
            all_chunks, manifest = [], {}
            for f in _collect_dir_files(dirpath, code_only=False):
                try:
                    manifest[str(f)] = f.stat().st_mtime
                    text = extract_file(f)
                    suffix = f.suffix.lower()
                    meta = {"file_path": str(f), "file_name": f.name,
                            "file_type": suffix.lstrip("."),
                            "obsidian_vault": vault["name"]}
                    all_chunks.extend(chunk_text(text, meta))
                except Exception as e:
                    logger.warning(f"Skipping {f}: {e}")
            ingest_chunks(all_chunks, coll, cfg)
            cfg = load_config()
            _save_persistent_source(cfg, {
                "type": "dir", "path": str(dirpath), "collection": coll,
                "manifest": manifest, "obsidian_vault": vault["name"],
            })
            print(f"   ✅ Vault '{vault['name']}' saved as persistent source ({len(manifest)} files)")
        return

    if args.file:
        path = Path(args.file)
        if not path.exists():
            print(f"❌ File not found: {path}")
            sys.exit(1)
        suffix = path.suffix.lower()
        if suffix == ".pdf":
            collection = args.collection or "pdfs"
            text = extract_file(path)
            meta = {"file_path": str(path), "file_name": path.name,
                    "file_type": "pdf", "ingested_date": datetime.now(timezone.utc).isoformat()}
            chunks = chunk_text(text, meta)
        elif suffix == ".docx":
            text = extract_file(path)
            meta = {"file_path": str(path), "file_name": path.name,
                    "file_type": "docx", "modified_date": str(path.stat().st_mtime)}
            chunks = chunk_text(text, meta)
        elif suffix in (".py", ".java", ".js", ".jsx", ".ts", ".tsx", ".html", ".css"):
            collection = args.collection or "code"
            chunks = chunk_code(path)
        else:
            text = extract_file(path)
            meta = {"file_path": str(path), "file_name": path.name, "file_type": suffix.lstrip(".")}
            chunks = chunk_text(text, meta)
        ingest_chunks(chunks, collection, cfg)

    elif args.dir:
        dirpath = Path(args.dir)
        if not dirpath.is_dir():
            print(f"❌ Not a directory: {dirpath}")
            sys.exit(1)
        all_chunks = []
        manifest = {}
        for f in _collect_dir_files(dirpath, code_only=False):
            try:
                manifest[str(f)] = f.stat().st_mtime
                suffix = f.suffix.lower()
                if suffix == ".pdf":
                    text = extract_file(f)
                    meta = {"file_path": str(f), "file_name": f.name, "file_type": "pdf",
                            "ingested_date": datetime.now(timezone.utc).isoformat()}
                    all_chunks.extend(chunk_text(text, meta))
                elif suffix == ".docx":
                    text = extract_file(f)
                    meta = {"file_path": str(f), "file_name": f.name, "file_type": "docx"}
                    all_chunks.extend(chunk_text(text, meta))
                else:
                    text = extract_file(f)
                    meta = {"file_path": str(f), "file_name": f.name, "file_type": suffix.lstrip(".")}
                    all_chunks.extend(chunk_text(text, meta))
            except Exception as e:
                logger.warning(f"Skipping {f}: {e}")
        ingest_chunks(all_chunks, collection, cfg)
        cfg = load_config()
        _save_persistent_source(cfg, {
            "type": "dir", "path": str(dirpath), "collection": collection, "manifest": manifest
        })
        print(f"✅ Saved as persistent source ({len(manifest)} files tracked)")

    elif args.codebase:
        dirpath = Path(args.codebase)
        if not dirpath.is_dir():
            print(f"❌ Not a directory: {dirpath}")
            sys.exit(1)
        collection = args.collection or "code"
        all_chunks = []
        manifest = {}
        for f in _collect_dir_files(dirpath, code_only=True):
            try:
                manifest[str(f)] = f.stat().st_mtime
                all_chunks.extend(chunk_code(f))
            except Exception as e:
                logger.warning(f"Skipping {f}: {e}")
        ingest_chunks(all_chunks, collection, cfg)
        cfg = load_config()
        _save_persistent_source(cfg, {
            "type": "codebase", "path": str(dirpath), "collection": collection, "manifest": manifest
        })
        print(f"✅ Saved as persistent source ({len(manifest)} files tracked)")

    elif args.url:
        collection = args.collection or "web"
        depth = args.depth or 0
        print(f"🔄 Crawling {args.url} (depth={depth})...")
        pages = crawl_url(args.url, depth=depth, ignore_robots=args.ignore_robots)
        print(f"   Found {len(pages)} pages")
        all_chunks = []
        page_hashes = {}
        seed_domain = args.url.split("/")[2] if "//" in args.url else ""
        for pg in pages:
            page_hashes[pg["url"]] = hashlib.sha256(pg["text"].encode()).hexdigest()
            meta = {
                "source_url": pg["url"],
                "page_title": pg["title"],
                "domain": seed_domain,
                "depth": depth,
                "crawl_root": args.url,
                "fetched_date": datetime.now(timezone.utc).date().isoformat(),
            }
            all_chunks.extend(chunk_text(pg["text"], meta))
        ingest_chunks(all_chunks, collection, cfg)

        if args.persistent:
            cfg = load_config()
            _save_persistent_source(cfg, {
                "type": "url", "url": args.url, "depth": depth, "collection": collection,
                "ignore_robots": args.ignore_robots, "page_hashes": page_hashes,
            })
            # Also register in web_sources for discoverability/management
            web_sources = cfg.get("web_sources", [])
            existing_urls = [w["url"] for w in web_sources]
            if args.url not in existing_urls:
                from urllib.parse import urlparse
                default_name = urlparse(args.url).netloc.replace("www.", "")
                web_sources.append({
                    "name": default_name, "url": args.url,
                    "depth": depth, "collection": collection,
                    "ignore_robots": args.ignore_robots,
                })
                cfg["web_sources"] = web_sources
                save_config(cfg)
            print(f"✅ Saved as persistent source ({len(page_hashes)} pages tracked)")
    else:
        print("❌ Specify one of: --file, --dir, --codebase, --url")
        sys.exit(1)


def cmd_collections(args, cfg):
    sub = args.subcommand

    if sub == "list":
        try:
            client = get_qdrant(cfg)
            colls = client.get_collections().collections
            if not colls:
                print("No collections found.")
                return
            print(f"{'Collection':<16} {'Docs':>8}")
            print("─" * 26)
            for c in sorted(colls, key=lambda x: x.name):
                info = client.get_collection(c.name)
                print(f"{c.name:<16} {info.points_count:>8}")
        except Exception as e:
            print(f"❌ {e}")

    elif sub == "status":
        cfg_data = load_config()
        sources = cfg_data.get("persistent_sources", [])
        if not sources:
            print("No persistent sources configured.")
            return
        print(f"{'Type':<10} {'Source':<48} {'Collection':<12} {'Tracked'}")
        print("─" * 82)
        for s in sources:
            stype = s.get("type", "url")
            label = s.get("path") or s.get("url", "")
            label = label[:47]
            coll = s.get("collection", "")
            if stype == "url":
                tracked = f"{len(s.get('page_hashes', {}))} pages"
            else:
                tracked = f"{len(s.get('manifest', {}))} files"
            print(f"{stype:<10} {label:<48} {coll:<12} {tracked}")

    elif sub == "refresh":
        cfg_data = load_config()
        sources = cfg_data.get("persistent_sources", [])
        if not sources:
            print("No persistent sources to refresh.")
            return
        updated_sources = []
        for s in sources:
            stype = s.get("type", "url")
            label = s.get("path") or s.get("url", "")
            print(f"\n🔄 [{stype}] {label}")
            if stype in ("dir", "codebase"):
                s = refresh_dir_source(s, cfg_data)
            elif stype == "url":
                s = refresh_url_source(s, cfg_data)
            else:
                print(f"   ⚠️  Unknown source type: {stype}")
            updated_sources.append(s)
        cfg_data["persistent_sources"] = updated_sources
        save_config(cfg_data)
        print("\n✅ Refresh complete. Manifests updated.")

    elif sub == "rebuild":
        name = args.name
        try:
            client = get_qdrant(cfg)
            if name == "--all":
                colls = [c.name for c in client.get_collections().collections]
            else:
                colls = [name]
            for c in colls:
                client.delete_collection(c)
                print(f"🗑️  Deleted collection: {c}")
            print("⚠️  Collections deleted. Re-ingest your sources to rebuild.")
        except Exception as e:
            print(f"❌ {e}")
    else:
        print(f"❌ Unknown subcommand: {sub}")
        sys.exit(1)


# ── Main ───────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="rag — personal RAG CLI (Qdrant + Ollama + sentence-transformers)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command")

    # status
    sub.add_parser("status", help="Check stack health")

    # query
    q = sub.add_parser("query", help="Query across collections")
    q.add_argument("query", help="Query string")
    q.add_argument("--json", action="store_true", help="Output JSON")
    q.add_argument("--collections", help="Comma-separated collection names")
    q.add_argument("--top-k", type=int, dest="top_k", help="Number of results")
    q.add_argument("--no-rerank", action="store_true", help="Skip reranker")

    # add
    a = sub.add_parser("add", help="Ingest content")
    a.add_argument("--file", help="Path to file")
    a.add_argument("--dir", help="Path to directory")
    a.add_argument("--codebase", help="Path to source code directory (tree-sitter chunking)")
    a.add_argument("--url", help="URL to crawl")
    a.add_argument("--obsidian", nargs="?", const="__all__", metavar="VAULT_NAME",
                   help="Ingest Obsidian vault(s) from config. Omit name to ingest all.")
    a.add_argument("--web", nargs="?", const="__all__", metavar="SOURCE_NAME",
                   help="Ingest web source(s) from config. Omit name to ingest all.")
    a.add_argument("--collection", help="Target collection (default: auto-detect)")
    a.add_argument("--depth", type=int, default=0, help="Crawl depth for --url")
    a.add_argument("--watch", action="store_true", help="Watch for changes (stub)")
    a.add_argument("--persistent", action="store_true", help="Re-crawl on rag collections refresh")
    a.add_argument("--ignore-robots", action="store_true", help="Ignore robots.txt")

    # collections
    c = sub.add_parser("collections", help="Manage collections")
    c.add_argument("subcommand", choices=["list", "status", "refresh", "rebuild"])
    c.add_argument("name", nargs="?", help="Collection name (for rebuild), or --all")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(0)

    cfg = load_config()

    if args.command == "status":
        cmd_status(args, cfg)
    elif args.command == "query":
        cmd_query(args, cfg)
    elif args.command == "add":
        cmd_add(args, cfg)
    elif args.command == "collections":
        cmd_collections(args, cfg)


if __name__ == "__main__":
    main()
